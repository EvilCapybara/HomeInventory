TELEGRAM_TOKEN=your_bot_token_here

DATABASE_NAME=database_name
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_username
DATABASE_PASSWORD=your_password

SQLALCHEMY_DATABASE_URI=postgresql://{DATABASE_USER}:{DATABASE_PASSWORD}@{DATABASE_HOST}:{DATABASE_PORT}/{DATABASE_NAME}

# Elasticsearch (оставьте пустым, чтобы отключить; поиск деградирует до PostgreSQL ILIKE)
ELASTICSEARCH_URL=http://localhost:9200

# Redis (по умолчанию: redis://localhost:6379)
REDIS_URL=redis://localhost:6379
